<?xml version="1.0"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" colors="true" xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.3/phpunit.xsd">
  <coverage>
    <report>
      <clover outputFile="coverage.xml" showUncoveredFiles="true"/>
    </report>
  </coverage>
  
  <testsuites>
    <testsuite name="main">
      <directory suffix="Test.php">.</directory>
    </testsuite>
  </testsuites>
  
  <logging/>
  
  <source>
    <include>
      <directory suffix=".php">.</directory>
    </include>
  </source>

</phpunit>